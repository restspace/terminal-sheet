{
  "name": "tsheet",
  "version": "0.1.0",
  "description": "Local-first browser canvas for supervising multiple AI terminal sessions.",
  "type": "module",
  "bin": {
    "tsheet": "dist/server/index.js",
    "terminal-canvas": "dist/server/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "dev": "tsx src/dev/devLauncher.ts",
    "dev:web": "vite --host 127.0.0.1 --port 4313 --strictPort --open",
    "dev:server": "cross-env NODE_ENV=development TERMINAL_CANVAS_DEV_WEB_URL=http://127.0.0.1:4313 tsx watch src/cli/index.ts serve --role home --no-open",
    "build": "npm run clean && npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "tsup src/cli/index.ts --format esm --target node20 --out-dir dist/server --clean --sourcemap",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src eslint.config.js vite.config.ts vitest.config.ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "terminal",
    "canvas",
    "pty",
    "react",
    "fastify"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.10.1",
    "fastify": "^5.8.2",
    "node-pty": "^1.1.0",
    "open": "^11.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  }
}
